# Fleet Watch secrets — copy to /opt/fleet-watch/fleet-watch.env, chmod 600.
# Never commit the real file to git.

# Telegram bot (can be the same bot as Repo Scout)
FLEET_TELEGRAM_BOT_TOKEN=
FLEET_TELEGRAM_CHAT_ID=

# Supabase Postgres connection strings (Session pooler URI from
# Dashboard > Project Settings > Database). Read-only usage enforced
# by the script via default_transaction_read_only.
CSUITE_DB_URL=
TJ_DB_URL=
